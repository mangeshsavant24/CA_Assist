
# LLM Configuration
# Provider options: 'ollama' (default, free, local) or 'openai' (requires API key)
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.1

# Ollama Configuration (for local LLM inference)
# Install: https://ollama.ai
# Start server: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
# Recommended models: 'mistral' (4.1GB), 'llama2' (7GB), 'neural-chat' (4.1GB)
# Install model: ollama pull mistral
OLLAMA_MODEL=mistral

# OpenAI Configuration (requires API key from https://platform.openai.com)
# Model options: 'gpt-4', 'gpt-3.5-turbo', 'gpt-4-turbo-preview'
OPENAI_API_KEY=sk-yourapikey
OPENAI_MODEL=gpt-3.5-turbo

# ChromaDB Configuration
CHROMA_PATH=./chroma_db/

# Authentication
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./ca_assist.db

